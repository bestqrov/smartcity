# Smart City Ecosystem - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# ── General ──────────────────────────────
NODE_ENV=production
PORT_GATEWAY=3000
PORT_USER_SERVICE=3001
PORT_TOURISM_SERVICE=3002
PORT_HEALTH_SERVICE=3003
PORT_EDUCATION_SERVICE=3004
PORT_SERVICES_SERVICE=3005
PORT_BILLING_SERVICE=3006
PORT_NOTIFICATION_SERVICE=3007

# ── Database (MongoDB) ──────────────────
# Example for MongoDB Atlas replica set:
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/smartcity?retryWrites=true&w=majority"

# ── Redis ────────────────────────────────
REDIS_URL="redis://redis:6379"

# ── JWT Authentication ───────────────────
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ── CORS ─────────────────────────────────
CORS_ORIGINS="http://localhost:3102,https://your-domain.com"
FRONTEND_URL="https://your-domain.com"

# ── Service URLs (used by gateway) ───────
USER_SERVICE_URL="http://user-service:3001"
TOURISM_SERVICE_URL="http://tourism-service:3002"

# ── Frontend ─────────────────────────────
NEXT_PUBLIC_API_URL="https://your-domain.com/api"
PORT_TOURISM_APP=3102
